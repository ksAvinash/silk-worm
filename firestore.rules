rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMember(businessId) {
      return isAuthenticated() &&
        request.auth.token.businessId is string &&
        request.auth.token.businessId == businessId;
    }

    function hasActiveBusinessUser(businessId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid)).data.active != false;
    }

    function isActiveMember(businessId) {
      return isMember(businessId) && hasActiveBusinessUser(businessId);
    }

    function isOwnerOrManager(businessId) {
      return isActiveMember(businessId) && request.auth.token.role in ["owner", "manager"];
    }

    function isPhoneBootstrapRead() {
      return isAuthenticated() &&
        request.auth.token.phone_number is string &&
        resource.data.phone is string &&
        request.auth.token.phone_number == resource.data.phone;
    }

    // Global user profile — readable/writable only by owning uid.
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // Business workspace root.
    match /businesses/{businessId} {
      allow read: if isActiveMember(businessId);
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwnerOrManager(businessId);
      allow delete: if false;

      match /slots/{docId} {
        allow read, create, update: if isActiveMember(businessId);
        allow delete: if isOwnerOrManager(businessId);
      }

      match /farmers/{docId} {
        allow read, create, update: if isActiveMember(businessId);
        allow delete: if isOwnerOrManager(businessId);
      }

      match /bookings/{docId} {
        allow read, create, update: if isActiveMember(businessId);
        allow delete: if isOwnerOrManager(businessId);
      }

      match /inventoryLedger/{docId} {
        allow read, create, update: if isActiveMember(businessId);
        allow delete: if false;
      }

      match /invoices/{docId} {
        allow read: if isActiveMember(businessId);
        allow create, update, delete: if isOwnerOrManager(businessId);
      }

      match /payments/{docId} {
        allow read: if isActiveMember(businessId);
        allow create, update, delete: if isOwnerOrManager(businessId);
      }

      match /reports/{docId} {
        allow read: if isActiveMember(businessId);
        allow create, update, delete: if isOwnerOrManager(businessId);
      }

      match /users/{docId} {
        allow read: if isActiveMember(businessId) || isPhoneBootstrapRead();

        // Claim-bearing admin path + claim-free first-login bootstrap path.
        allow create: if isOwnerOrManager(businessId) || (
          isAuthenticated() &&
          request.auth.uid == docId &&
          request.resource.data.role in ["owner", "manager", "operator"] &&
          request.resource.data.phone == request.auth.token.phone_number
        );

        allow update: if isOwnerOrManager(businessId) || (
          isActiveMember(businessId) &&
          request.auth.uid == docId &&
          request.resource.data.role == resource.data.role
        );

        allow delete: if isOwnerOrManager(businessId);
      }
    }
  }
}
