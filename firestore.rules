rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myBusinessId() {
      return myProfile().businessId;
    }

    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        businessDoc(businessId).ownerUid == request.auth.uid;
    }

    function isMyBusiness(businessId) {
      return isBusinessOwner(businessId) || (hasUserProfile() && businessId == myBusinessId());
    }

    function isOwnerOrManager(businessId) {
      return isBusinessOwner(businessId) || (
        hasUserProfile() &&
        businessId == myBusinessId() &&
        myProfile().role in ["owner", "manager"]
      );
    }

    // Auth profile mapping (global by uid)
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // Business root document
    match /businesses/{businessId} {
      allow read: if isMyBusiness(businessId);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      allow delete: if false;

      // All business-owned data must live in these subcollections
      match /slots/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update: if isMyBusiness(businessId);
        allow delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /farmers/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update: if isMyBusiness(businessId);
        allow delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /bookings/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update: if isMyBusiness(businessId);
        allow delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /inventoryLedger/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update: if isMyBusiness(businessId);
        allow delete: if false;
      }

      match /invoices/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update, delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /payments/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update, delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /reports/{docId} {
        allow read: if isMyBusiness(businessId);
        allow create, update, delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }

      match /users/{docId} {
        allow read: if isMyBusiness(businessId);
        // Owners/managers manage team users.
        // A user can also create/update their own business user doc for bootstrap at login.
        allow create: if isMyBusiness(businessId) && (
          isOwnerOrManager(businessId) ||
          (
            isSignedIn() &&
            hasUserProfile() &&
            request.auth.uid == docId &&
            request.resource.data.role == myProfile().role
          )
        );
        allow update: if isMyBusiness(businessId) && (
          isOwnerOrManager(businessId) ||
          (
            isSignedIn() &&
            hasUserProfile() &&
            request.auth.uid == docId &&
            request.resource.data.role == resource.data.role
          )
        );
        allow delete: if isMyBusiness(businessId) && isOwnerOrManager(businessId);
      }
    }
  }
}
